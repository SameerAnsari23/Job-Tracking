# ─── Required ─────────────────────────────────────────────────────────────────
# Backend API origin including the /api/v1 prefix.
VITE_API_BASE_URL=http://localhost:3000/api/v1

# ─── Optional ─────────────────────────────────────────────────────────────────
# development | staging | production (default: development)
VITE_ENV_NAME=development

# Show TanStack Query devtools (default: false; forced off in production builds)
VITE_ENABLE_DEVTOOLS=true

# Error reporting DSN — leave unset to disable reporting
# VITE_SENTRY_DSN=

# Comma-separated feature-flag overrides for local development, e.g.:
# VITE_FLAGS=adminArea,passwordReset
# VITE_FLAGS=
